body {
    font-family: Arial, sans-serif;
    margin: 0;
    background-color: #0a0a0a;
    color: #ffffff;
}

header {
    background-color: #000000;
    padding: 20px;
}

header ul {
    list-style: none;
    display: flex;
    gap: 20px;
}

header ul li a {
    color: #ffffff;
    text-decoration: none;
    font-weight: bold;
}

.hero {
    text-align: center;
    padding: 100px 20px;
}

.btn {
    background-color: #d4af37;
    color: #000000;
    padding: 15px 30px;
    margin: 10px;
    display: inline-block;
    text-decoration: none;
    font-weight: bold;
    border-radius: 5px;
}

.btn-secondary {
    background-color: transparent;
    border: 2px solid #d4af37;
    color: #d4af37;
}

footer {
    text-align: center;
    padding: 20px;
    background-color: #000000;
}
